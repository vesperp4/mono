# Postgres connection string used by the API and the integration tests.
# Local dev (matches `docker run ... postgres:17`):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vesperp4

# Email: with ACS_ENDPOINT/ACS_SENDER_ADDRESS unset, the API refuses to start
# unless you explicitly allow the log-only sender (it prints sign-in links,
# incl. raw tokens, to the console — local/CI only, never a deployed env).
ALLOW_LOG_EMAIL_SENDER=true
