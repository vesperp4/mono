#!/usr/bin/env bash
set -euo pipefail

# Devpod-only project wiring (skip on contributor laptops).
if [ "${DEVPOD:-}" = "true" ]; then
  git config --global push.autoSetupRemote true
  git config --global --add safe.directory /workspaces/mono
  pre-commit install
  pre-commit install --hook-type commit-msg
fi
